# Config
CONFIG_PATH=config/backends.yaml

# Gateway settings
LOG_LEVEL=info
GATEWAY_PORT=8080

# Tenant API keys
TENANT_ALPHA_KEY=test-alpha-key
TENANT_BETA_KEY=test-beta-key

# Backend API keys (mock backends accept any key)
OPENAI_API_KEY=test-openai-key
ANTHROPIC_API_KEY=test-anthropic-key

# Redis (for rate limiting)
REDIS_URL=redis://redis:6379/0

# Semantic cache
CACHE_TTL=3600
CACHE_SIMILARITY_THRESHOLD=0.95

# Priority queue
QUEUE_MAX_DEPTH=100
QUEUE_TIMEOUT=30

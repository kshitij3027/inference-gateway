# Config
CONFIG_PATH=config/backends.yaml

# Gateway settings
LOG_LEVEL=info
GATEWAY_PORT=8080
INSTANCE_ID=gateway-1

# Tenant API keys
TENANT_ALPHA_KEY=test-alpha-key
TENANT_BETA_KEY=test-beta-key

# Backend API keys (mock backends accept any key)
OPENAI_API_KEY=test-openai-key
ANTHROPIC_API_KEY=test-anthropic-key

# Redis (for rate limiting)
REDIS_URL=redis://redis:6379/0

# Semantic cache
CACHE_TTL=3600
CACHE_SIMILARITY_THRESHOLD=0.95
L1_MAX_ENTRIES=500
L1_TTL=3600

# Priority queue
QUEUE_MAX_DEPTH=100
QUEUE_TIMEOUT=30

# Request journal
JOURNAL_MAX_LEN=100000

# Chaos testing (disabled by default)
CHAOS_ENABLED=false
CHAOS_ERROR_RATE=0.10
CHAOS_TIMEOUT_RATE=0.05
CHAOS_LATENCY_RATE=0.30
CHAOS_LATENCY_MIN_MS=50
CHAOS_LATENCY_MAX_MS=2000

{
  "uid": "per-backend-drilldown",
  "title": "Per-Backend Drilldown",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "backend",
        "label": "Backend",
        "type": "query",
        "query": "label_values(gateway_request_total, backend)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {},
        "definition": "label_values(gateway_request_total, backend)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(gateway_request_duration_seconds_bucket{backend=\"$backend\"}[5m])) by (le))",
          "legendFormat": "P50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_seconds_bucket{backend=\"$backend\"}[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(gateway_request_duration_seconds_bucket{backend=\"$backend\"}[5m])) by (le))",
          "legendFormat": "P99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gateway_request_total{backend=\"$backend\",status_code=~\"5..\"}[5m])) / sum(rate(gateway_request_total{backend=\"$backend\"}[5m])) * 100",
          "legendFormat": "Error Rate",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Active Concurrent Requests",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "gateway_active_requests{backend=\"$backend\"}",
          "legendFormat": "Active Requests",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Circuit Breaker State",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "CLOSED", "color": "green", "index": 0 },
                "1": { "text": "OPEN", "color": "red", "index": 1 },
                "2": { "text": "HALF_OPEN", "color": "yellow", "index": 2 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 },
              { "color": "yellow", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "gateway_circuit_breaker_state{backend=\"$backend\"}",
          "legendFormat": "Circuit Breaker",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Volume",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gateway_request_total{backend=\"$backend\"}[1m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ]
}

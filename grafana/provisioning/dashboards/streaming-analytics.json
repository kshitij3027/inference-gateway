{
  "uid": "streaming-analytics",
  "title": "Streaming Analytics",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "5s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "TTFT P50/P95/P99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(gateway_ttft_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(gateway_ttft_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(gateway_ttft_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "ITL P50/P95/P99",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(gateway_itl_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(gateway_itl_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(gateway_itl_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Generation Duration by Model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(gateway_generation_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} P50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(gateway_generation_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} P95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Effective Tokens/Second",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "tok/s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 / histogram_quantile(0.50, sum(rate(gateway_itl_seconds_bucket[5m])) by (le))",
          "legendFormat": "Tokens/sec (median)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TTFT Distribution (Bucket Rates)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gateway_ttft_seconds_bucket{le=\"0.01\"}[5m]))",
          "legendFormat": "≤10ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "B",
          "expr": "sum(rate(gateway_ttft_seconds_bucket{le=\"0.05\"}[5m])) - sum(rate(gateway_ttft_seconds_bucket{le=\"0.01\"}[5m]))",
          "legendFormat": "10-50ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "C",
          "expr": "sum(rate(gateway_ttft_seconds_bucket{le=\"0.25\"}[5m])) - sum(rate(gateway_ttft_seconds_bucket{le=\"0.05\"}[5m]))",
          "legendFormat": "50-250ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "D",
          "expr": "sum(rate(gateway_ttft_seconds_bucket{le=\"1.0\"}[5m])) - sum(rate(gateway_ttft_seconds_bucket{le=\"0.25\"}[5m]))",
          "legendFormat": "250ms-1s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "E",
          "expr": "sum(rate(gateway_ttft_seconds_bucket{le=\"+Inf\"}[5m])) - sum(rate(gateway_ttft_seconds_bucket{le=\"1.0\"}[5m]))",
          "legendFormat": ">1s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "ITL Distribution (Bucket Rates)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gateway_itl_seconds_bucket{le=\"0.005\"}[5m]))",
          "legendFormat": "≤5ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "B",
          "expr": "sum(rate(gateway_itl_seconds_bucket{le=\"0.01\"}[5m])) - sum(rate(gateway_itl_seconds_bucket{le=\"0.005\"}[5m]))",
          "legendFormat": "5-10ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "C",
          "expr": "sum(rate(gateway_itl_seconds_bucket{le=\"0.05\"}[5m])) - sum(rate(gateway_itl_seconds_bucket{le=\"0.01\"}[5m]))",
          "legendFormat": "10-50ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "D",
          "expr": "sum(rate(gateway_itl_seconds_bucket{le=\"0.25\"}[5m])) - sum(rate(gateway_itl_seconds_bucket{le=\"0.05\"}[5m]))",
          "legendFormat": "50-250ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "E",
          "expr": "sum(rate(gateway_itl_seconds_bucket{le=\"+Inf\"}[5m])) - sum(rate(gateway_itl_seconds_bucket{le=\"0.25\"}[5m]))",
          "legendFormat": ">250ms",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ]
}
